# Local infra: docker/compose.env + docker/docker-compose.yml (or docker/up.ps1, docker/up.sh)
PORT=3000

# CORS: comma-separated browser origins (scheme + host + port only, no path). Required for production
# when the frontend is not on localhost — e.g. Render/Vercel/Netlify frontend calling this API on Render.
# Example: https://your-app.vercel.app or https://your-frontend.onrender.com
# Multiple: https://app.example.com,https://www.example.com
# If unset, only http://localhost:5173 and http://127.0.0.1:5173 are allowed (Vite default).
# FRONTEND_ORIGIN=https://your-deployed-frontend.example.com

# Set to true to run without Postgres/Mongo (e.g. local UI/Swagger only)
# SKIP_DB=true

# --- Postgres / Supabase ---
# When DATABASE_URL is set, TypeORM uses it and ignores POSTGRES_* below.
#
# Direct connection (simplest for local Nest + TypeORM). From Supabase Dashboard →
# Project Settings → Database → Connection string → URI (direct, port 5432).
# Replace YOUR_PROJECT_REF and YOUR_DB_PASSWORD.
# DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
#
# Pooler (PgBouncer, port 6543) — optional for production / many connections.
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
#
# Optional: Prisma-style direct URL for migration tools / SQL clients only (Nest does not read this).
# DIRECT_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Local Docker Postgres only — used when DATABASE_URL is unset
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=dukaan

# Postgres schema: applied via TypeORM migrations (src/database/migrations). synchronize is always off.
# On startup, pending migrations run automatically unless:
# TYPEORM_MIGRATIONS_RUN=false
#
# New migration from entities (empty DB or after DB matches last migration), then commit the file:
#   yarn migration:generate src/database/migrations/DescribeChange
# Review the SQL; prefer additive changes. Production: deploy runs migrations before serving traffic.
# Optional: yarn migration:run (uses DATABASE_URL from .env.local)
# TYPEORM_LOGGING=true

# --- MongoDB ---
# Nest reads MONGODB_URI (Mongoose). Local Docker or mongod:
# MONGODB_URI=mongodb://127.0.0.1:27017/dukaan
#
# MongoDB Atlas (or other cloud): Cluster → Connect → Drivers → copy connection string.
# Replace <password> and keep database name at the end (e.g. /dukaan).
# MONGODB_URI=mongodb+srv://USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/dukaan?retryWrites=true&w=majority&appName=Cluster0
MONGODB_URI=mongodb://127.0.0.1:27017/dukaan

# Firebase Auth → Postgres user sync (POST /auth/sync)
# Production: paste the full service account JSON (one line) from Firebase Console → Project settings → Service accounts
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Local dev without service account: trust firebaseUid from the client (never enable in production)
# SYNC_AUTH_DEV=true

# OpenTelemetry (OTLP HTTP — e.g. Jaeger all-in-one :4318, Grafana Alloy, etc.)
OTEL_SERVICE_NAME=backend
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4318/v1/traces
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318

# CSV bulk import (POST /shops/:id/products/import-csv/from-path)
# Absolute directory on the server; relativePath in the body must stay under it.
# CSV_IMPORT_BASE_DIR=C:\\data\\dukaan-csv
# Default selling price in ₹ when a row has no price column (optional).
# CSV_IMPORT_DEFAULT_PRICE_RUPEES=1

# --- Supabase Storage (S3 API) — presigned browser uploads (POST /storage/presign-upload)
# Dashboard → Project Settings → Storage → S3 connection: endpoint, region, access key, secret.
# SUPABASE_S3_ENDPOINT=https://YOUR_PROJECT_REF.storage.supabase.co/storage/v1/s3
# SUPABASE_S3_REGION=your_region_from_dashboard
# SUPABASE_S3_ACCESS_KEY_ID=
# SUPABASE_S3_SECRET_ACCESS_KEY=
# Public project URL (no trailing slash) — used to build object URLs saved in contents.storageUrl
# SUPABASE_PUBLIC_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_STORAGE_PUBLIC_BUCKET=dukan-pro-public-documents
# SUPABASE_STORAGE_PRIVATE_BUCKET=dukan-pro-documents
