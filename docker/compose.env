# Used by docker compose (--env-file docker/compose.env). Matches backend .env.example defaults.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dukaan
POSTGRES_PORT=5432

MONGO_PORT=27017

# Jaeger UI (traces)
JAEGER_UI_PORT=16686
# OTLP HTTP (same as OTEL_EXPORTER_OTLP_ENDPOINT in .env)
OTLP_HTTP_PORT=4318
